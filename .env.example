##############################################################################
# .env.example  –  SkillSwap
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git — it contains secrets.
##############################################################################

# ── Flask ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
FLASK_ENV=development          # change to 'production' on server

# ── Database ──────────────────────────────────────────────────────────────────
# Docker Compose sets this automatically — only change for external DB
DATABASE_URL=postgresql://skillswap:skillswap@postgres:5432/skillswap

# ── Redis ─────────────────────────────────────────────────────────────────────
# Docker Compose sets this automatically — only change for external Redis
REDIS_URL=redis://redis:6379/0

# ── Email (optional — for future notification emails) ─────────────────────────
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_USE_TLS=true
